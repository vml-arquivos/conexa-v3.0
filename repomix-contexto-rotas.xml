                          objetivoCurriculo={sequenciaAtiva.objetivoCurriculo}
                          faixaEtariaPadrao={faixaEtaria}
                        />
                      </div>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )}
      </section>

