    setSavingMicrogesto(true);
    try {
      await createMicrogestureEvent({
        childId: modalCrianca.id,
        classroomId: data.classroom.id,
        kind: microgestoRapido,
        payload: { texto: microgestoTexto || undefined },
        eventDate: new Date().toISOString(),
