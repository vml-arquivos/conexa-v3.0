                                </button>
                                <button
                                  onClick={() => aprovarPedido(p.id)}
                                  disabled={aprovando === p.id}
                                  className="flex items-center gap-2 px-4 py-2 bg-green-600 text-white rounded-lg text-sm font-medium hover:bg-green-700 disabled:opacity-50"
