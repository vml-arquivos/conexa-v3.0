                          onClick={() => toast.success('Marcado como aplicado!')}>
                          <CheckCircle className="h-3 w-3 mr-1" /> Aplicado
                        </Button>
                      </div>
                    </CardContent>
                  </Card>
                );
              })}
            </div>
          )}
        </div>
      )}
    </PageShell>
  );
}
