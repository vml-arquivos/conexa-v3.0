              <p className="text-sm text-gray-500">Semanal (unidade) e Mensal (coordenação geral)</p>
            </div>
            <Button onClick={() => setModalPauta(true)} className="flex items-center gap-2">
              <Plus className="h-4 w-4" /> Nova Pauta
            </Button>
