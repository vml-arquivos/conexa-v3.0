                            {day.teacher?.observacoes && (
                              <div>
                                <p className="text-xs font-semibold text-gray-400 uppercase mb-0.5">Observações</p>
                                <p className="text-sm text-gray-700 whitespace-pre-wrap">{day.teacher.observacoes}</p>
