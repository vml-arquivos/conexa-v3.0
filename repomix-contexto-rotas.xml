                        </tbody>
                      </table>
                    </CardContent>
                  </Card>
                </>
              )}
            </div>
          )}

          {/* ── ABA: POR PROFESSOR ───────────────────────────────────────────── */}
          {(activeTab as string) === 'professores' && (
            <div className="space-y-6">
