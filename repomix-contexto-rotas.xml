                              </div>
                            </div>
                          )}

                          {/* Observações do pedido */}
                          {p.observacoes && (
                            <div className="mt-3 p-3 bg-gray-50 rounded-lg border text-sm text-gray-600">
                              <span className="font-medium">Observações: </span>{p.observacoes}
                            </div>
                          )}
                        </div>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      )}

      {/* ── Aba: Equipe ── */}
      {aba === 'equipe' && (
        <div className="space-y-4">
