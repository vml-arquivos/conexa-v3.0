                    {matrix.name}
                  </td>
                  <td className="px-6 py-4 text-sm text-gray-500">
                    {matrix.description || '-'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}
