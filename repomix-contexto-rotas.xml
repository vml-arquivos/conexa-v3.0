    };
    alunos.forEach(a => {
      const rdics = rdicsMap[a.id] ?? [];
      const status = resolveRdicStatus(rdics, trimestre);
      grupos[status]?.push(a);
    });
    return grupos;
  }, [alunos, rdicsMap, trimestre]);

