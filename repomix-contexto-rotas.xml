      </div>
    );
  }

  return (
    <div>
      <h1 className="text-3xl font-bold mb-6">Matrizes Curriculares</h1>
      {matrices.length === 0 ? (
        <div className="bg-white p-6 rounded-lg shadow text-center text-gray-500">
          Nenhuma matriz encontrada
