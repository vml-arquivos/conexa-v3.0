                      <div className="flex-1">
                        <div className="flex items-center gap-2 mb-1 flex-wrap">
                          <Badge className={`text-xs ${pauta.tipo === 'SEMANAL_UNIDADE' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700'}`}>
